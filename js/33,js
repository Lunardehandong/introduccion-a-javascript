// Async / await

// Función que simula una consulta asíncrona a una base de datos o API externa
function descargarNuevosClientes() {
    return new Promise( resolve => {
        console.log('Descargando clientes... espere...');

        // Simula una demora de 5 segundos (5000 milisegundos)
        setTimeout( () => {
            resolve('Los Clientes fueron Descargados');
        }, 5000 );
    });
}

// 2. Segundo Método: Simula descargar los últimos pedidos (Tarda 3 segundos)
function descargarUltimosPedidos() {
    return new Promise( resolve => {
        console.log('Descargando pedidos... espere...');

        setTimeout( () => {
            resolve('Los Pedidos fueron Descargados');
        }, 3000 );
    });
}

// 3. Resto de las líneas: Función principal y ejecución optimizada
async function app() {
    try {
        // En lugar de esperar 5s por los clientes y LUEGO 3s por los pedidos (8s en total)...
        // Promise.all arranca AMBAS descargas al mismo tiempo en paralelo.
        const resultado = await Promise.all([ descargarNuevosClientes(), descargarUltimosPedidos() ]);
        
        // El resultado es un arreglo con las respuestas en el mismo orden en que se llamaron
        console.log(resultado[0]); // Muestra: 'Los Clientes fueron Descargados'
        console.log(resultado[1]); // Muestra: 'Los Pedidos fueron Descargados'
        
    } catch (error) {
        // Si CUALQUIERA de las promesas del arreglo falla, el control cae directo aquí
        console.log(error);
    }
}

app();
